# Copy this file to .env for local development.
# Never commit real API keys.

# DeepSeek hosted API profiles.
# Official base URL at the time this was added: https://api.deepseek.com
DEEPSEEK_BASE_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_API_KEY=replace-with-your-deepseek-api-key

# Generic OpenAI-compatible endpoint for local vLLM, SGLang, LiteLLM, or another provider.
ADIP_OPENAI_BASE_URL=http://127.0.0.1:8000/v1
ADIP_OPENAI_API_KEY=local-dev-key
